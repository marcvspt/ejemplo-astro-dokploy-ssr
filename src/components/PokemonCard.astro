---
import PokemonStatItem from "@/components/PokemonStatItem.astro";
---

<article
    id="pokemon-card"
    class="mt-6 hidden rounded-2xl border border-border bg-surface-muted p-5"
>
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start">
        <img
            id="pokemon-image"
            src=""
            alt=""
            class="h-36 w-36 rounded-xl bg-surface object-contain p-2 shadow"
        />
        <div class="w-full">
            <h2
                id="pokemon-name"
                class="text-2xl font-bold capitalize text-text-primary"
            >
            </h2>
            <p id="pokemon-id" class="mt-1 text-sm text-text-secondary"></p>
            <p id="pokemon-types" class="mt-2 text-sm text-text-body"></p>
            <p id="pokemon-size" class="mt-1 text-sm text-text-body"></p>
        </div>
    </div>

    <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <PokemonStatItem label="HP" valueId="stat-hp" />
        <PokemonStatItem label="Attack" valueId="stat-attack" />
        <PokemonStatItem label="Defense" valueId="stat-defense" />
        <PokemonStatItem label="Speed" valueId="stat-speed" />
    </div>
</article>
